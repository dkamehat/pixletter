# .audit-patterns.example v2
# Copy this file to .audit-patterns.txt for local or CI audits.
# .audit-patterns.txt is gitignored and MUST NEVER be committed.
#
# Format:
#   label<TAB>regular-expression
#
# Rules:
# - Do not put sensitive literal values in this template.
# - Prefer category regexes, escaped code points, or CI secrets.
# - The audit script reports only file path, line number, and label.
# - Do not print or commit matched text.

# Work or private email addresses. Keep public placeholder domains allowed.
tier3_email	[A-Za-z0-9._%+-]+@(?!example\.(?:com|org|net)\b|your-domain\.com\b)[A-Za-z0-9.-]+\.[A-Za-z]{2,}

# Machine-specific local paths.
tier3_local_path	(?:[A-Za-z]:[\\/]+Users[\\/]+[^\\/\s]+[\\/]|[/]Users[/][^/\s]+[/]|[/]home[/][^/\s]+[/])

# Delivery-company / prior-project references encoded to avoid plain sensitive values.
tier3_delivery_company	(?:\u51fa\u524d\u9928|\x44\x65\x6d\x61\x65[-_\s]?\x43\x61\x6e)

# Internal project/system references should be added as regexes in CI secrets or local files,
# not as plain literal values in this committed template.
