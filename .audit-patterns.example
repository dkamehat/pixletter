# .audit-patterns.example v1.1
# This file is committed to the repository as a template.
# Copy this to .audit-patterns.txt and replace placeholders with REAL VALUES.
# .audit-patterns.txt is gitignored and MUST NEVER be committed.
#
# Tier policy (v1.1):
#   Tier 1 (personal brand) and Tier 2 (career facts) are intentionally NOT covered here.
#   Only Tier 3 (business confidential) is monitored.
#
# Format: one pattern per line, lines starting with # are comments.
# Empty lines are ignored.

# === Category: Self identifying information (private email only) ===
<SELF_EMAIL_PERSONAL_FULL>
<SELF_EMAIL_PERSONAL_LOCALPART>
<SELF_EMAIL_WORK_FULL>
<SELF_EMAIL_WORK_LOCALPART>

# === Category: Current employer (intentionally empty - public via LinkedIn) ===

# === Category: Coworkers (last names) ===
<COWORKER_LAST_NAME_1>
<COWORKER_LAST_NAME_2>
<COWORKER_LAST_NAME_3>
<COWORKER_LAST_NAME_4>
<COWORKER_LAST_NAME_5>
# (Add more lines as needed for additional coworkers)

# === Category: Candidate companies (job applications) ===
<CANDIDATE_COMPANY_1>
<CANDIDATE_COMPANY_2>
<CANDIDATE_COMPANY_3>
<CANDIDATE_COMPANY_4>
<CANDIDATE_COMPANY_5>
<CANDIDATE_COMPANY_6>
<CANDIDATE_COMPANY_7>
<CANDIDATE_COMPANY_8>
# (Add casing variations if needed - e.g. "KOMOJU" and "Komoju")

# === Category: Internal projects ===
<INTERNAL_PROJECT_CODENAME_1>
<INTERNAL_PROJECT_CODENAME_1_SHORT>
<INTERNAL_PROJECT_CODENAME_2>

# === Category: Store / client names ===
<STORE_OR_CLIENT_NAME_1>
<STORE_OR_CLIENT_NAME_2>
# (Add only if explicitly mentioned in past communications)

# === Category: Business context terms (intentionally empty - industry is public) ===

# === Category: Internal terminology / system names (in-house coined terms only) ===
<INTERNAL_SYSTEM_NAME_1>
<INTERNAL_SYSTEM_NAME_2>
# (General tool names like BigQuery, AppSheet, Spiral, Salesforce are NOT included)

# === Category: Online identifiers (work-related only) ===
<WORK_EMAIL_DOMAIN>

# === Category: Local file paths (machine-specific) ===
<LOCAL_PATH_USERNAME_WINDOWS>
<LOCAL_PATH_USERNAME_UNIX>