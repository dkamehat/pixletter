#!/bin/sh
# Pre-commit hook: L1 audit on staged files.
# Configured via: git config core.hooksPath .githooks
# Self-Reference Test must pass on this file (zero hardcoded patterns).

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
AUDIT_SCRIPT="$REPO_ROOT/scripts/audit.py"

if [ ! -f "$AUDIT_SCRIPT" ]; then
  echo "ERROR: audit script not found at $AUDIT_SCRIPT" >&2
  exit 2
fi

# Python command resolution.
# NOTE: Windows ships a fake "python3" alias that opens Microsoft Store and
# exits 9009. So we must VERIFY the command actually runs, not just exists.
PY=""
for cand in python python3; do
  if "$cand" --version >/dev/null 2>&1; then
    PY="$cand"
    break
  fi
done

if [ -z "$PY" ]; then
  echo "ERROR: no working python found in PATH" >&2
  exit 2
fi

"$PY" "$AUDIT_SCRIPT" --staged
